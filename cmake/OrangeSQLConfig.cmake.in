# ============================================
# OrangeSQL CMake Configuration
# ============================================

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find required dependencies
find_dependency(Threads)
find_dependency(nlohmann_json)

# Optional dependencies
find_dependency(Readline)

# Include targets
if(NOT TARGET orangesql::orangesql_core)
    include("${CMAKE_CURRENT_LIST_DIR}/OrangeSQLTargets.cmake")
endif()

# Define variables
set(ORANGESQL_VERSION "@PROJECT_VERSION@")
set(ORANGESQL_INCLUDE_DIR "@CMAKE_INSTALL_PREFIX@/include")
set(ORANGESQL_LIBRARY_DIR "@CMAKE_INSTALL_PREFIX@/lib")

# Create imported targets
if(NOT TARGET orangesql::orangesql)
    add_executable(orangesql::orangesql IMPORTED)
    set_target_properties(orangesql::orangesql PROPERTIES
        IMPORTED_LOCATION "@CMAKE_INSTALL_PREFIX@/bin/orangesql"
    )
endif()

# Check required components
check_required_components(orangesql)